import pandas as pd

# 1. 파일 불러오기 (인코딩 주의: 한국어 데이터이므로 cp949 또는 utf-8-sig 사용)
file_path = 'pill_data.csv'
output_path = 'pill_data_cleaned.csv'

# 데이터 읽기
# 보통 공공데이터 CSV는 'cp949'인 경우가 많습니다. 에러 시 'utf-8'로 변경하세요.
try:
    df = pd.read_csv(file_path, encoding='cp949')
except UnicodeDecodeError:
    df = pd.read_csv(file_path, encoding='utf-8')

print(f"정제 전 데이터 개수: {len(df)}개")

# 2. 중복 제거 (첫 번째 컬럼 기준)
# '품목기준코드' 또는 컬럼 인덱스 0번을 기준으로 합니다.
# 만약 컬럼명이 정확하지 않다면 df.columns[0]를 사용합니다.
target_column = df.columns[0] 

# 중복된 행 중 첫 번째(first)만 남기고 제거
df_cleaned = df.drop_duplicates(subset=[target_column], keep='first')

print(f"정제 후 데이터 개수: {len(df_cleaned)}개")
print(f"삭제된 중복 데이터: {len(df) - len(df_cleaned)}개")

# 3. 결과 저장 (BOM을 포함한 UTF-8로 저장해야 한글이 깨지지 않습니다)
df_cleaned.to_csv(output_path, index=False, encoding='utf-8-sig')

print(f"성공적으로 '{output_path}' 파일이 생성되었습니다.")